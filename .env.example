APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Single-DB: use the landlord connection as default so `php artisan migrate`, sessions, cache, and queue tables share one MySQL database with tenant-scoped data.
DB_CONNECTION=landlord
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Optional overrides for the landlord connection. If unset, landlord uses DB_* above.
# LANDLORD_DB_DATABASE=laravel

SESSION_DRIVER=database
# Use the same connection as app data when SESSION_DRIVER=database
SESSION_CONNECTION=landlord
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=landlord

CACHE_STORE=database
DB_CACHE_CONNECTION=landlord
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_your_key_here
STRIPE_SECRET=sk_test_your_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
IMPASTAY_ONBOARDING_GCASH_ACCOUNT_NAME=ImpaStay
IMPASTAY_ONBOARDING_GCASH_NUMBER=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Release registry sync (two-layer update system)
GITHUB_REPO=
GITHUB_TOKEN=

# Single-DB migration rollout flags
# When SINGLE_DB_ALLOW_TENANT_SWITCHING=false, all tenant-scoped data uses the landlord connection and one MySQL database. Apply schema: php artisan single-db:migrate (or php artisan migrate with DB_CONNECTION=landlord).
SINGLE_DB_MIGRATION_ENABLED=true
SINGLE_DB_READS=true
SINGLE_DB_WRITES=true
SINGLE_DB_SHADOW_READS=false
SINGLE_DB_ALLOW_LEGACY_PROVISIONING=false
SINGLE_DB_ALLOW_TENANT_SWITCHING=false

# Optional: explicit name for the legacy `tenant` connection (defaults to landlord/DB_* — same physical database as single-DB production).
# TENANT_DB_DATABASE=
# TENANT_DB_CONNECTION=mysql
